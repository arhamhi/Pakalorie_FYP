rules_version = '2';

// Pakalorie FYP — Firestore security rules.
// Since CDX-001 (2026-07-02) ALL user data lives in Firestore: the profile doc
// at users/{uid} plus per-user subcollections (food_logs, hydration,
// chat_sessions, favorites, weight_logs) under it. A signed-in user may read
// and write only their own tree; everything else is denied by default.
//
// Deploy: `firebase deploy --only firestore:rules`, or paste into
// Firebase Console > Firestore Database > Rules > Publish.

service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      match /{collection}/{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }
  }
}
