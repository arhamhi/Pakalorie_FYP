# Mobile app
# Live FastAPI deploy (VPS, public HTTPS). The app falls back to this same URL
# if the var is unset; override here only to point at a different backend.
EXPO_PUBLIC_API_BASE_URL=https://api.srv987636.hstgr.cloud
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# Backend (FastAPI) — set in the on-box backend/.env on the VPS, not committed
# DATABASE_URL=postgresql+asyncpg://user:pass@host/db
# GEMINI_API_KEY=
