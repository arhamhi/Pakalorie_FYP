# Local dev:
DATABASE_URL=postgresql+asyncpg://pakalorie:pakalorie@localhost:5432/pakalorie
#
# Production VPS example:
# DATABASE_URL=postgresql+asyncpg://pakalorie:<POSTGRES_PASSWORD>@pakalorie-postgres:5432/pakalorie
GEMINI_API_KEY=
CORS_ORIGINS=https://*.expo.dev,exp://*,http://localhost:8081,http://localhost:19006
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta
# MiDaS depth model for POST /portion (download: python -m scripts.download_midas)
MIDAS_MODEL_PATH=models/midas_small_256.onnx
