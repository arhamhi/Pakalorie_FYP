{
  "expo": {
    "name": "Pakalorie",
    "slug": "pakalorie-fyp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "pakalorie",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.redolanse.pakaloriefyp",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "NSCameraUsageDescription": "Khane ki photos capture karne ke liye camera access chahiye.",
        "NSLocationWhenInUseUsageDescription": "Paas ke healthy restaurants suggest karne ke liye location chahiye.",
        "NSPhotoLibraryUsageDescription": "Gallery se photos select karne ke liye access chahiye."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1BAD66"
      },
      "package": "com.redolanse.pakaloriefyp",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "READ_EXTERNAL_STORAGE"
      ],
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      "expo-image-picker",
      "expo-location",
      "expo-dev-client",
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          }
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.562903530107-fdcg3jnkgljs993l84dg3armuodk96bi"
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#1BAD66",
          "sounds": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "googleSignInWebClientId": "562903530107-cbu9mkdqg5mokdlbucmakd56hg8o7lqi.apps.googleusercontent.com",
      "googleSignInIosClientId": "562903530107-fdcg3jnkgljs993l84dg3armuodk96bi.apps.googleusercontent.com"
    }
  }
}
