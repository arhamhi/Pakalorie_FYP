{
  "expo": {
    "name": "Pakalorie",
    "slug": "pakalorie",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "pakalorie",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#121212"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.redolanse.pakalorie",
      "infoPlist": {
        "NSCameraUsageDescription": "Khane ki photos capture karne ke liye camera access chahiye.",
        "NSLocationWhenInUseUsageDescription": "Paas ke healthy restaurants suggest karne ke liye location chahiye.",
        "NSPhotoLibraryUsageDescription": "Gallery se photos select karne ke liye access chahiye."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1BAD66"
      },
      "package": "com.redolanse.pakalorie",
      "permissions": [
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "READ_EXTERNAL_STORAGE"
      ],
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      "expo-image-picker",
      "expo-location",
      [
        "expo-notifications",
        {
          "color": "#1BAD66",
          "sounds": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
